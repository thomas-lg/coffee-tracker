        "required": [
          "registrationEnabled"
        ],
        "type": "object",
        "properties": {
          "registrationEnabled": {
            "type": "boolean"
          }
        }
      },
      "FlavorTagDto": {
        "required": [
          "id",
          "name"
        ],
        "type": "object",
        "properties": {
          "id": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "IFormFile": {
        "type": "string",
