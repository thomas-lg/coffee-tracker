{
  "ConnectionStrings": {
    "Default": "Data Source=coffee.db"
  },
  "Storage": {
    "PhotosPath": "photos",
    "MaxPhotoBytes": 5242880
  },
  "Jwt": {
    "Issuer": "coffee-tracker",
    "Audience": "coffee-tracker"
  },
  "Ocr": {
    "Engine": "tesseract",
    "Language": "eng",
    "TimeoutSeconds": 30,
    "MaxConcurrency": 0
  },
  "REGISTRATION_ENABLED": false,
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    }
  },
  "FileLog": {
    "Directory": "logs"
  },
  "AllowedHosts": "*"
}
